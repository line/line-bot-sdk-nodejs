// Base config for editor/IDE type-checking. Includes tests and vite.config.ts
// so they get the same compiler settings (e.g. moduleResolution: Bundler) as
// the source. noEmit is true because builds use tsconfig.esm.json /
// tsconfig.cjs.json, which extend this one (or mirror its settings).
{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "noImplicitAny": true,
    "newLine": "LF",
    "sourceMap": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDirs": ["lib", "test"],
    "types": ["node"],
    "declaration": true,
    "noEmit": true,
  },
  "include": [
    "lib/**/*.ts",
    "test/**/*.ts",
    "vite.config.ts",
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".git",
    // Materialized into standalone projects at test time (with @line/bot-sdk npm-installed there).
    "test/consumer/templates"
  ],
}
