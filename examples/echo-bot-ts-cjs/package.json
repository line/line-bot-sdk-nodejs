{
  "name": "echo-bot-ts-cjs",
  "version": "0.0.0",
  "description": "A LINE Messaging API SDK for Node.js bot example using TypeScript with CJS",
  "main": "./dist/index.js",
  "scripts": {
    "clean": "rimraf ./dist",
    "build": "npm run clean && tsc",
    "build-sdk": "npm --prefix ../.. run build && npm install --no-save --package-lock=false @line/bot-sdk@file:../..",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@line/bot-sdk": "11.0.1",
    "express": "5.2.1"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "25.9.1",
    "rimraf": "6.1.3",
    "typescript": "6.0.3"
  }
}
