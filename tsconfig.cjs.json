// CJS build config (emits dist/cjs/). Standalone (not extending tsconfig.json)
// because it needs module: CommonJS / target: es2017 for the legacy CJS output.
{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "es2017",
    "outDir": "./dist/cjs",
    "sourceMap": true,
    "declarationMap": true,
    "declaration": true,
    "rootDirs": ["lib"]
  },
  "include": [
    "lib/**/*.ts",
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".git",
    "lib/**/tests/**"
  ]
}
