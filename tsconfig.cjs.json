// CJS build config (emits dist/cjs/). Extends tsconfig.json and overrides
// module / target for the legacy CJS output.
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "target": "es2017",
    "outDir": "./dist/cjs",
    "rootDir": "lib",
    "noEmit": false
  },
  "include": [
    "lib/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".git",
    "lib/**/tests/**"
  ]
}
